# .env.example — Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# cp .env.example .env

# JWT imzalama anahtarı — En az 32 karakter, tahmin edilemez olmalı.
# Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=buraya-guclu-bir-anahtar-girin

# "production" olarak set edin → cookie secure=True olur
ENVIRONMENT=development

# Veritabanı bağlantısı (boş bırakılırsa SQLite kullanılır)
# DATABASE_URL=postgresql://user:password@localhost/edem
DATABASE_URL=

# E-posta (SMTP) — boş bırakılırsa email gönderme atlanır (log uyarısı yazılır)
# Gmail için: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=...@gmail.com
# Uygulama Şifresi (App Password) gerekir, normal şifre değil:
# https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=1

# Uygulama URL'si — email içindeki "listeyi gör" linki için
# Örn: https://prizmafinans-production.up.railway.app
APP_URL=
